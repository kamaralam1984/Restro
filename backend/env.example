# Copy to .env and fill values. Do not commit .env.

# Server
PORT=5000
NODE_ENV=development

# Database (required)
MONGODB_URI=mongodb://localhost:27017/restro-os

# JWT (required in production; change default in prod)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS (production: comma-separated origins, e.g. https://yourapp.com,https://www.yourapp.com)
CORS_ORIGIN=
FRONTEND_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# WhatsApp (optional — order/booking alerts)
# Get URL + Key from: Twilio WhatsApp, MessageBird, or WhatsApp Cloud API.
# Leave empty in dev: messages will only log to console.
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
# Restaurant admin phone to receive alerts (with country code, e.g. +919876543210)
ADMIN_PHONE=

# Admin token (optional, for some legacy flows)
ADMIN_TOKEN=

# Logging (optional: error | warn | info | debug)
LOG_LEVEL=debug

# Scripts: create-admin
ADMIN_EMAIL=admin@silverplate.com
ADMIN_PASSWORD=Admin@123

# Scripts: create-super-admin
SUPER_ADMIN_EMAIL=superadmin@restroos.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# Scripts: create-master-admin
MASTER_ADMIN_EMAIL=masteradmin@restroos.com
MASTER_ADMIN_PASSWORD=MasterAdmin@123

# Restaurant create: public app URL for store links
PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
