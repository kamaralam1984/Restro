# Copy to .env.local and fill values. Do not commit .env.local.

# API (required for auth and data)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App URL (for sitemap, robots, restaurant links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Restaurant context (optional; for single-tenant signup/login)
NEXT_PUBLIC_RESTAURANT_ID=

# Razorpay (for checkout/booking payment)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
